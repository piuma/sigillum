# Compile gettext catalogues + translated man pages alongside the Python
# build, then install them under /usr/share/{locale,man}/.
override_dh_auto_build:
	dh_auto_build
	$(MAKE) -C po compile
	$(MAKE) -C docs man

override_dh_auto_install:
	dh_auto_install
	$(MAKE) -C po install DESTDIR=$(CURDIR)/debian/sigillum prefix=/usr
	$(MAKE) -C docs install DESTDIR=$(CURDIR)/debian/sigillum prefix=/usr
