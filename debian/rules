#!/usr/bin/make -f
# debian/rules per sigillum
# Vedi debhelper(7) e debhelper-compat(7).

export PYBUILD_NAME=sigillum
# Network and hardware tests are excluded from the build daemons.
export PYBUILD_TEST_ARGS=-m "not network and not hardware"

%:
	dh $@ --with python3 --buildsystem=pybuild
